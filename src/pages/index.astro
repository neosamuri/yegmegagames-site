---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="YEG Megagames hosts large-scale tabletop megagame events in Edmonton, Alberta." />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>YEG Megagames | Edmonton Megagame Events</title>
    <link rel="icon" type="image/png" href="/img/cropped-iconpng.png" />
  </head>

  <body class="bg-zinc-950 text-zinc-100">
    <main class="min-h-screen">
      <header class="sticky top-0 z-50 border-b border-yellow-500/20 bg-zinc-950/90 backdrop-blur">
        <div class="mx-auto flex max-w-7xl items-center justify-between px-5 py-4">
          <a href="/" class="flex items-center gap-3 no-underline">
            <img src="/img/cropped-iconpng.png" alt="" class="h-10 w-10" />
            <span class="text-xl font-black tracking-wide text-yellow-400">YEG Megagames</span>
          </a>

          <nav class="hidden gap-6 text-sm font-bold uppercase tracking-widest text-zinc-300 md:flex">
            <a class="no-underline hover:text-yellow-400" href="#next-event">Next Event</a>
            <a class="no-underline hover:text-yellow-400" href="#events">Events</a>
            <a class="no-underline hover:text-yellow-400" href="#about">About</a>
            <a class="no-underline hover:text-yellow-400" href="#community">Community</a>
            <a class="no-underline hover:text-yellow-400" href="/store-twp">Store</a>
          </nav>
        </div>
      </header>

      <section class="relative overflow-hidden border-b border-yellow-500/20">
        <div class="absolute inset-0 bg-[linear-gradient(rgba(0,0,0,.78),rgba(0,0,0,.88)),url('/img/66849364_10161901310555386_1504923014003687424_o.jpg')] bg-cover bg-center"></div>
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(234,179,8,.24),transparent_35%),radial-gradient(circle_at_bottom_right,rgba(127,29,29,.42),transparent_35%)]"></div>

        <div class="relative mx-auto grid max-w-7xl gap-10 px-5 py-16 lg:grid-cols-[1fr_0.95fr] lg:items-center lg:py-24">
          <section>
            <img src="/img/logopng.png" alt="YEG Megagames" class="mb-8 w-72 max-w-full drop-shadow-2xl sm:w-96" />

            <p class="mb-4 text-sm font-black uppercase tracking-[0.35em] text-yellow-400">
              Edmonton's Megagame Community
            </p>

            <h1 class="max-w-3xl text-5xl font-black leading-none text-white sm:text-6xl lg:text-7xl">
              Big games. Bigger stories.
            </h1>

            <p class="mt-6 max-w-2xl text-lg leading-8 text-zinc-200">
              Join large-scale tabletop strategy events filled with diplomacy, negotiation,
              teamwork, chaos, alliances, betrayals, and unforgettable decisions.
            </p>

            <div class="mt-8 flex flex-wrap gap-4">
              <a href="#next-event" class="rounded-md bg-yellow-500 px-6 py-3 text-sm font-black uppercase tracking-wider text-zinc-950 no-underline shadow-lg hover:bg-yellow-400">
                View Next Event
              </a>
              <a href="/store-twp" class="rounded-md border border-yellow-500/70 px-6 py-3 text-sm font-black uppercase tracking-wider text-yellow-300 no-underline hover:bg-yellow-500/10">
                Visit The Store
              </a>
            </div>
          </section>

          <section id="next-event" class="rounded-2xl border border-yellow-500/30 bg-zinc-900/95 p-6 shadow-2xl shadow-black/60 backdrop-blur">
            <div id="featured-event">
              <p class="text-zinc-300">Loading next megagame...</p>
            </div>
          </section>
        </div>
      </section>

      <section id="events" class="bg-zinc-900 px-5 py-16 lg:py-20">
        <div class="mx-auto max-w-7xl">
          <div class="mb-10 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
            <div>
              <p class="mb-3 text-sm font-black uppercase tracking-[0.3em] text-yellow-400">Upcoming</p>
              <h2 class="text-4xl font-black text-white sm:text-5xl">Events</h2>
            </div>
          </div>

          <div id="events-grid" class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
            <p class="text-zinc-300">Loading events...</p>
          </div>
        </div>
      </section>

      <section id="about" class="border-y border-yellow-500/20 bg-zinc-950 px-5 py-16 lg:py-20">
        <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
          <div>
            <p class="mb-3 text-sm font-black uppercase tracking-[0.3em] text-yellow-400">What Is A Megagame?</p>
            <h2 class="text-4xl font-black text-white sm:text-5xl">
              Part board game, part roleplaying, part beautiful chaos.
            </h2>
          </div>

          <div class="space-y-5 text-lg leading-8 text-zinc-300">
            <p>
              Megagames are large-scale social strategy games where dozens of players take on roles,
              negotiate with other teams, respond to crises, and shape a shared story over a single event day.
            </p>
            <p>
              New players are welcome. Come ready to talk, scheme, collaborate, panic, and have a memorable day.
            </p>
          </div>
        </div>
      </section>

      <section id="community" class="bg-zinc-900 px-5 py-16 lg:py-20">
        <div class="mx-auto max-w-7xl rounded-2xl border border-yellow-500/30 bg-zinc-950 p-8 text-center shadow-2xl shadow-black/50">
          <img src="/img/cropped-iconpng.png" alt="" class="mx-auto mb-6 h-16 w-16" />
          <h2 class="text-4xl font-black text-white sm:text-5xl">Join the YEG Megagames Discord</h2>
          <p class="mx-auto mt-5 max-w-2xl text-lg leading-8 text-zinc-300">
            Meet other players, get event announcements, find teams, and stay up to date on upcoming Edmonton megagames.
          </p>

          <div class="mt-8 flex flex-wrap justify-center gap-4">
            <a href="https://discord.gg/gpVh2X6sKu" target="_blank" rel="noopener noreferrer" class="rounded-md bg-yellow-500 px-6 py-3 text-sm font-black uppercase tracking-wider text-zinc-950 no-underline hover:bg-yellow-400">
              Join Discord
            </a>
          </div>
        </div>
      </section>

      <footer class="border-t border-yellow-500/20 bg-zinc-950 px-5 py-8 text-center text-sm text-zinc-500">
        <p>YEG Megagames · Edmonton, Alberta</p>
      </footer>
    </main>

    <script>
      const featuredEvent = document.querySelector('#featured-event');
      const eventsGrid = document.querySelector('#events-grid');

      function escapeHtml(value) {
        return String(value ?? '')
          .replaceAll('&', '&amp;')
          .replaceAll('<', '&lt;')
          .replaceAll('>', '&gt;')
          .replaceAll('"', '&quot;')
          .replaceAll("'", '&#039;');
      }

      function isTrue(value) {
        const cleaned = String(value ?? '').trim().toLowerCase();
        return cleaned === 'true' || cleaned === 'yes' || cleaned === '1';
      }

      function isVisible(event) {
        const cleaned = String(event.visible ?? '').trim().toLowerCase();
        return cleaned !== 'false' && cleaned !== 'no' && cleaned !== '0';
      }

      function getPlayerPercent(event) {
        const count = Number(event.player_count ?? 0);
        const max = Number(event.max_players ?? 0);
        return max > 0 ? Math.min(Math.round((count / max) * 100), 100) : 0;
      }

      function getEventImage(event) {
        const image = String(event.image ?? '').trim();
        return image || '/img/67084676_10161901306805386_5924142824818737152_n-1.jpg';
      }

      function sortEvents(events) {
        return [...events].sort((a, b) => {
          const aDate = new Date(a.date ?? '').getTime();
          const bDate = new Date(b.date ?? '').getTime();
          if (Number.isNaN(aDate) && Number.isNaN(bDate)) return 0;
          if (Number.isNaN(aDate)) return 1;
          if (Number.isNaN(bDate)) return -1;
          return aDate - bDate;
        });
      }

      function renderFeaturedEvent(event) {
        if (!featuredEvent) return;

        if (!event) {
          featuredEvent.innerHTML = '<p class="text-zinc-300">No upcoming events are currently listed.</p>';
          return;
        }

        const playerPercent = getPlayerPercent(event);
        const playerCount = Number(event.player_count ?? 0);
        const maxPlayers = Number(event.max_players ?? 0);
        const rsvpUrl = String(event.rsvp_url ?? '').trim();

        featuredEvent.innerHTML = `
          <div class="mb-6 flex items-center justify-between gap-4">
            <p class="text-sm font-black uppercase tracking-[0.25em] text-yellow-400">Next Megagame</p>
            ${event.status ? `<span class="rounded-full border border-red-700/60 bg-red-950/50 px-3 py-1 text-xs font-black uppercase tracking-wider text-red-200">${escapeHtml(event.status)}</span>` : ''}
          </div>

          <div class="mb-6 overflow-hidden rounded-xl border border-yellow-500/20 bg-gradient-to-br from-zinc-600 via-zinc-700 to-zinc-900 shadow-lg shadow-yellow-500/10">
            <img src="${escapeHtml(getEventImage(event))}" alt="" class="h-72 w-full object-contain p-4" />
          </div>

          <h2 class="text-4xl font-black leading-tight text-white">${escapeHtml(event.title)}</h2>

          <div class="mt-5 grid gap-3 text-zinc-300">
            ${event.date ? `<p><span class="font-bold text-yellow-400">Date:</span> ${escapeHtml(event.date)}</p>` : ''}
            ${event.time ? `<p><span class="font-bold text-yellow-400">Time:</span> ${escapeHtml(event.time)}</p>` : ''}
            ${event.location ? `<p><span class="font-bold text-yellow-400">Location:</span> ${escapeHtml(event.location)}</p>` : ''}
          </div>

          ${event.description ? `<p class="mt-6 rounded-xl border border-zinc-700/70 bg-zinc-950/50 p-5 leading-8 text-zinc-200">${escapeHtml(event.description)}</p>` : ''}

          <div class="mt-8">
            <div class="mb-2 flex justify-between text-sm font-bold text-zinc-300">
              <span>Current Player Count</span>
              <span>${playerCount} / ${maxPlayers}</span>
            </div>
            <div class="h-4 overflow-hidden rounded-full bg-zinc-800 ring-1 ring-yellow-500/20">
              <div class="h-full rounded-full bg-yellow-500" style="width: ${playerPercent}%"></div>
            </div>
          </div>

          ${rsvpUrl
            ? `<a href="${escapeHtml(rsvpUrl)}" target="_blank" rel="noopener noreferrer" class="mt-8 block rounded-md bg-red-800 px-6 py-4 text-center text-sm font-black uppercase tracking-wider text-white no-underline hover:bg-red-700">RSVP / Reserve Your Seat</a>`
            : `<p class="mt-8 rounded-md border border-zinc-700 bg-zinc-950 px-6 py-4 text-center font-bold text-zinc-300">RSVP link coming soon.</p>`
          }
        `;
      }

      function renderEventCards(events) {
        if (!eventsGrid) return;

        if (!events.length) {
          eventsGrid.innerHTML = '<p class="text-zinc-300">No upcoming events are currently listed.</p>';
          return;
        }

        eventsGrid.innerHTML = events.map((event) => {
          const count = Number(event.player_count ?? 0);
          const max = Number(event.max_players ?? 0);
          const percent = getPlayerPercent(event);
          const rsvpUrl = String(event.rsvp_url ?? '').trim();

          return `
            <article class="overflow-hidden rounded-xl border border-zinc-700 bg-zinc-950 shadow-lg shadow-black/30">
              <div class="bg-gradient-to-br from-zinc-600 via-zinc-700 to-zinc-900">
                <img src="${escapeHtml(getEventImage(event))}" alt="" class="h-48 w-full object-contain p-3" />
              </div>
              <div class="p-6">
                <div class="mb-5 flex items-center justify-between gap-4">
                  ${event.status ? `<span class="rounded-full bg-yellow-500/10 px-3 py-1 text-xs font-black uppercase tracking-wider text-yellow-300">${escapeHtml(event.status)}</span>` : ''}
                  ${isTrue(event.featured) ? `<span class="rounded-full bg-red-800/40 px-3 py-1 text-xs font-black uppercase tracking-wider text-red-100">Featured</span>` : ''}
                </div>

                <h3 class="text-2xl font-black text-white">${escapeHtml(event.title)}</h3>

                <div class="mt-4 space-y-2 text-sm text-zinc-300">
                  ${event.date ? `<p>${escapeHtml(event.date)}</p>` : ''}
                  ${event.time ? `<p>${escapeHtml(event.time)}</p>` : ''}
                  ${event.location ? `<p class="text-zinc-400">${escapeHtml(event.location)}</p>` : ''}
                </div>

                ${event.description ? `<p class="mt-5 line-clamp-4 leading-7 text-zinc-400">${escapeHtml(event.description)}</p>` : ''}

                <div class="mt-6">
                  <div class="mb-2 flex justify-between text-xs font-bold uppercase tracking-wider text-zinc-400">
                    <span>Players</span>
                    <span>${count} / ${max}</span>
                  </div>
                  <div class="h-2.5 overflow-hidden rounded-full bg-zinc-800">
                    <div class="h-full rounded-full bg-yellow-500" style="width: ${percent}%"></div>
                  </div>
                </div>

                ${rsvpUrl
                  ? `<a href="${escapeHtml(rsvpUrl)}" target="_blank" rel="noopener noreferrer" class="mt-6 inline-flex font-black uppercase tracking-wider text-yellow-400 no-underline hover:text-yellow-300">RSVP →</a>`
                  : `<p class="mt-6 font-bold text-zinc-500">RSVP coming soon</p>`
                }
              </div>
            </article>
          `;
        }).join('');
      }

      let currentEvents = [];

      function parsePlayerCount(value) {
        const count = Number(value);
        return Number.isFinite(count) && count >= 0 ? Math.floor(count) : 0;
      }

      async function fetchLivePlayerCount(event) {
        const apiUrl = String(event.playerCountApi ?? '').trim();
        if (!apiUrl) return parsePlayerCount(event.player_count);

        try {
          const url = new URL(apiUrl);
          url.searchParams.set('_refresh', Date.now().toString());

          const response = await fetch(url.toString(), {
            cache: 'no-store',
            redirect: 'follow',
          });

          if (!response.ok) {
            throw new Error(`Player count request failed: ${response.status}`);
          }

          const data = await response.json();
          return parsePlayerCount(data.count ?? data.player_count);
        } catch (error) {
          console.warn(`Could not refresh player count for ${event.title ?? 'event'}`, error);
          return parsePlayerCount(event.player_count);
        }
      }

      async function refreshPlayerCounts() {
        if (!currentEvents.length) return;

        const refreshedEvents = await Promise.all(
          currentEvents.map(async (event) => ({
            ...event,
            player_count: String(await fetchLivePlayerCount(event)),
          }))
        );

        currentEvents = refreshedEvents;
        const nextEvent = currentEvents.find((event) => isTrue(event.featured)) ?? currentEvents[0];
        renderFeaturedEvent(nextEvent);
        renderEventCards(currentEvents);
      }

      async function loadEvents() {
        try {
          const response = await fetch(`/api/events.json?_refresh=${Date.now()}`, { cache: 'no-store' });
          if (!response.ok) throw new Error(`Failed to load events: ${response.status}`);

          const allEvents = await response.json();
          const visibleEvents = allEvents.filter(isVisible);
          currentEvents = sortEvents(visibleEvents);

          const nextEvent = currentEvents.find((event) => isTrue(event.featured)) ?? currentEvents[0];
          renderFeaturedEvent(nextEvent);
          renderEventCards(currentEvents);

          await refreshPlayerCounts();
        } catch (error) {
          console.error(error);
          if (featuredEvent) featuredEvent.innerHTML = '<p class="text-red-200">Events could not be loaded right now.</p>';
          if (eventsGrid) eventsGrid.innerHTML = '<p class="text-red-200">Events could not be loaded right now.</p>';
        }
      }

      loadEvents();
      window.setInterval(refreshPlayerCounts, 60_000);
    </script>
  </body>
</html>
